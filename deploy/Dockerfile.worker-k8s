FROM python:3.12-slim
WORKDIR /app
RUN pip install --no-cache-dir -U pip
COPY packages/fixops-contract /build/packages/fixops-contract
COPY services/worker-k8s /build/services/worker-k8s
COPY config /app/config
RUN pip install --no-cache-dir /build/packages/fixops-contract /build/services/worker-k8s
EXPOSE 8083
CMD ["uvicorn", "fixops_worker_k8s.app:app", "--host", "0.0.0.0", "--port", "8083"]
