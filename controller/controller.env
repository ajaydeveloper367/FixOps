# Controller only (`CONTROLLER_*`). Lives with the controller mini-project.
# Required: standalone K8s worker HTTP base (no trailing slash). Start worker with:
#   fixops-worker-k8s-serve
CONTROLLER_WORKER_K8S_BASE_URL=http://127.0.0.1:8080

# LLM: Ollama OpenAI-compatible API — used for narrative `summary_lines` after each investigation.
# Start Ollama: `scripts/ollama-llama.sh start` — model name must match `ollama list`.

CONTROLLER_LLM_BASE_URL=http://127.0.0.1:11434/v1
CONTROLLER_LLM_MODEL=llama3.2:latest
