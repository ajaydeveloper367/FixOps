# worker-k8s only (`WORKER_K8S_*`). Lives with the worker mini-project.
# Multi-cluster: relative paths resolve from this directory (workers/worker_k8s/).
WORKER_K8S_CLUSTER_MAP_PATH=cluster-map.local.yaml
# LLM: Ollama — rewrites the facts bundle into the structured `WorkerResponse` JSON (falls back to deterministic if the call fails).
# Start Ollama: `scripts/ollama-llama.sh start` — model name must match `ollama list`.

WORKER_K8S_LLM_BASE_URL=http://127.0.0.1:11434/v1
WORKER_K8S_LLM_MODEL=llama3.2:latest
